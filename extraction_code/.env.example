# TrueFoundry AI Gateway (OpenAI-compatible)
# Copy to .env and fill in real values from the TrueFoundry Playground "Code Snippets" tab.
TFY_GATEWAY_URL=https://gateway.truefoundry.ai
TFY_API_KEY=your_truefoundry_api_key
# Groq vision model id as shown in your TrueFoundry Playground, e.g. groq-main/llama-3.2-90b-vision-preview
TFY_MODEL=groq-main/llama-3.2-90b-vision-preview
