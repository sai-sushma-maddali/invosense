# Composio (Gmail polling)
COMPOSIO_API_KEY=
COMPOSIO_USER_ID=default
COMPOSIO_GMAIL_AUTH_CONFIG_ID=

# Google OAuth (used via Composio custom auth)
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_OAUTH_REDIRECT_URI=https://backend.composio.dev/api/v3.1/toolkits/auth/callback

# TrueFoundry / extraction
TFY_GATEWAY_URL=https://gateway.truefoundry.ai
TFY_API_KEY=
TFY_MODEL=anthropic/claude-sonnet-4-6
EXTRACT_WITH_BOXES=true
TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe

# Polling
GMAIL_POLL_INTERVAL_SEC=30
FOLDER_POLL_INTERVAL_SEC=5
WATCH_FOLDER=data/watch

# ClickHouse Cloud
CLICKHOUSE_HOST=
CLICKHOUSE_PORT=8443
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DATABASE=invosense
CLICKHOUSE_SECURE=true
CLICKHOUSE_CONNECT_TIMEOUT=15
