PORT=3000

# FastAPI backend (extract → compliance → decision)
BACKEND_URL=http://localhost:8001

# ── Coinbase CDP ─────────────────────────────────────────────────────────────
# Create a project at https://portal.cdp.coinbase.com and copy these values.
CDP_API_KEY=your_cdp_api_key_here
CDP_WALLET_ID=your_testnet_wallet_id

# NEVER commit this key. Fund via: https://faucet.quicknode.com/base/sepolia
WALLET_PRIVATE_KEY=0x_your_base_sepolia_private_key_here

# ── cited.md ─────────────────────────────────────────────────────────────────
# Leave blank to use the built-in stub (returns mock URLs).
CITED_API_URL=https://api.cited.md/v1/publish
CITED_API_KEY=your_cited_api_key_here

# ── FX (MOCK — clearly not a real rate) ──────────────────────────────────────
# 1 MYR = 0.22 USDC (mock rate for testnet demos only)
MOCK_FX_MYR_TO_USDC=0.22
